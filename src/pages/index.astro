---
import { Image } from 'astro:assets';
import '@fontsource-variable/inter';
import '@fontsource-variable/jetbrains-mono';

import archiveDesk from '../assets/case-desk-hero.png';
import bureauLab from '../assets/bureau-data-lab.png';
import HomeArcStory from '../components/HomeArcStory.astro';
import course from '../data/course.json';
import { homeStoryDetails } from '../data/home-stories';

const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

const withBase = (path: string) => `${base}${path.replace(/^\//, '')}`;
const archive = course.arcs.find((arc) => arc.id === 'part-1')!;
const bureau = course.arcs.find((arc) => arc.id === 'part-2')!;

const prepareStoryArc = (arc: (typeof course.arcs)[number]) => ({
  ...arc,
  cases: arc.cases.map((item) => {
    const detail = homeStoryDetails[item.number];
    if (!detail) throw new Error(`Missing homepage story metadata for ${item.number}`);
    return { ...item, ...detail, href: withBase(item.route) };
  }),
});

const archiveStory = prepareStoryArc(archive);
const bureauStory = prepareStoryArc(bureau);

const guideLink = withBase('/field-guide/');
const materialsLink = withBase('/materials/');
const skillMapLink = withBase('/skill-map/');
const canonical = Astro.site ? new URL(base, Astro.site) : null;
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="Двенадцать учебных проектов: шесть Python-скриптов и шесть тетрадей Jupyter по анализу данных и машинному обучению."
    />
    <meta name="theme-color" content="#0b0e12" />
    <meta property="og:title" content="Python-расследования" />
    <meta
      property="og:description"
      content="Сначала создаём программы на Python. Затем анализируем данные и обучаем модели."
    />
    <meta property="og:type" content="website" />
    {canonical && <link rel="canonical" href={canonical} />}
    <title>Python-расследования · от улик к моделям</title>
    <link rel="icon" href={`${base}images/favicon.svg`} />
  </head>
  <body data-phase="archive">
    <a class="skip-link" href="#course-main">К основному содержанию</a>

    <header class="site-header" data-site-header>
      <a class="header-brand" href={base} aria-current="page">Python-расследования</a>
      <nav aria-label="Основная навигация">
        <a href={withBase(archive.route)}>Часть I</a>
        <a href={withBase(bureau.route)}>Часть II</a>
        <a href={materialsLink}>Материалы</a>
        <a href={guideLink}>Справочник</a>
      </nav>
    </header>

    <main id="course-main">
      <section class="course-hero" aria-labelledby="home-title">
        <Image
          class="hero-image"
          src={archiveDesk}
          widths={[768, 1280, 1680, 2200]}
          sizes="100vw"
          format="avif"
          loading="eager"
          fetchpriority="high"
          alt="Ночной рабочий стол с ноутбуком, документами и материалами расследования"
        />
        <div class="hero-shade" aria-hidden="true"></div>
        <div class="hero-content">
          <p class="hero-kicker">Проектный учебник · Python и ML</p>
          <h1 id="home-title">
            <span>Python-<br />расследования</span>
            <small>Сначала создаём программы на Python.<br />Затем анализируем данные и обучаем модели.</small>
          </h1>
          <p class="hero-summary">
            Курс состоит из двенадцати проектов: шести Python-скриптов и шести тетрадей Jupyter по анализу данных и машинному обучению.
          </p>
          <div class="hero-actions" aria-label="Выбрать маршрут">
            <a class="button primary" href={withBase(archive.route)}>Начать с части I</a>
            <a class="button glass" href={withBase(bureau.route)}>Перейти к части II</a>
          </div>
        </div>
        <a class="hero-scroll" href="#progression">
          <span>Две арки · двенадцать дел</span>
          <i aria-hidden="true"></i>
        </a>
      </section>

      <section class="progression" id="progression" aria-labelledby="progression-title">
        <p class="section-index">Маршрут курса</p>
        <h2 id="progression-title">Сначала разберём готовый фрагмент кода.<br />Затем дополним программу и проверим на материалах расследования.</h2>
        <p>
          В Части I вы шаг за шагом создадите шесть программ на Python: сравните тексты, найдёте совпадения, разберёте email, проверите содержимое папки, сохраните материалы дела и сформируете итоговый отчёт. В Части II вы продолжите работу в Jupyter: исследуете данные, обучите модели и проверите их на новых примерах.
        </p>
      </section>

      <HomeArcStory
        id="archive-story"
        mode="archive"
        eyebrow="Часть I · Архив"
        title="Северный стол"
        description="В шести проектах вы сравните тексты, проверите письма и файлы, сохраните материалы дела в JSON и подготовите итоговый отчёт."
        note="Без опыта программирования · 90–150 минут на дело · Python-скрипты"
        overviewHref={withBase(archive.route)}
        overviewLabel="Открыть обзор первой части"
        cases={archiveStory.cases}
      />

      <section
        class="handoff"
        data-arc-phase="bureau"
        aria-labelledby="handoff-title"
      >
        <Image
          class="handoff-image"
          src={bureauLab}
          widths={[768, 1280, 1717]}
          sizes="100vw"
          format="avif"
          loading="lazy"
          alt="Аналитик сверяет печатную таблицу с графиками и матрицей ошибок на ноутбуке"
        />
        <div class="handoff-shade" aria-hidden="true"></div>
        <div class="handoff-copy">
          <p class="section-index">Вербовка · апрель 2026</p>
          <h2 id="handoff-title">Во второй части вы перейдёте от Python-скриптов к Jupyter и машинному обучению.</h2>
          <p>
            Вы подготовите данные, разделите их на обучающую и тестовую выборки, сравните модели и разберёте ошибки.
          </p>
        </div>
      </section>

      <HomeArcStory
        id="bureau-story"
        mode="bureau"
        eyebrow="Часть II · Бюро"
        title="Протокол «Компас»"
        description="В шести тетрадях Jupyter вы проверите признаки и разбиения, сравните метрики и проанализируете ошибки моделей."
        note="После части I · 3–5 часов на дело · финал 6–8 часов · Jupyter Notebook"
        overviewHref={withBase(bureau.route)}
        overviewLabel="Открыть обзор Бюро"
        cases={bureauStory.cases}
      />

      <section class="method" aria-labelledby="method-title">
        <p class="section-index">Один принцип</p>
        <h2 id="method-title">Каждое ML-дело состоит из трёх шагов.</h2>
        <div class="method-flow">
          <div><span>01</span><strong>Соберите</strong><p>Прочитайте досье и воспроизведите заявленный результат.</p></div>
          <div><span>02</span><strong>Проверьте</strong><p>Найдите утечки, слабые разбиения и систематические ошибки.</p></div>
          <div><span>03</span><strong>Сформулируйте</strong><p>Запишите полученные метрики, объясните их значение, перечислите ограничения модели и решите, можно ли её использовать.</p></div>
        </div>
      </section>

      <section class="course-close" aria-labelledby="close-title">
        <p class="section-index">Выберите точку входа</p>
        <h2 id="close-title">Начните с основ Python<br />или перейдите к машинному обучению.</h2>
        <div class="close-actions">
          <a class="button paper" href={withBase(archive.route)}>Начать часть I</a>
          <a class="button cobalt" href={withBase(bureau.route)}>Начать часть II</a>
          <a class="text-link dark-link" href={skillMapLink}>Сравнить навыки двух частей</a>
        </div>
      </section>
    </main>

    <footer>
      <a href={base}>Python-расследования</a>
      <nav aria-label="Ссылки в подвале">
        <a href={materialsLink}>Материалы</a>
        <a href={guideLink}>Справочник</a>
        <a href={skillMapLink}>Карта навыков</a>
      </nav>
    </footer>

    <script is:inline type="module">
      const body = document.body;
      const stories = Array.from(document.querySelectorAll("[data-arc-story]"));
      const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)");
      let frame = 0;

      const clamp = (value, min = 0, max = 1) => Math.min(Math.max(value, min), max);

      function setActive(story, index) {
        const steps = Array.from(story.querySelectorAll("[data-case-step]"));
        const visuals = Array.from(story.querySelectorAll("[data-visual-case]"));
        const safeIndex = clamp(index, 0, Math.max(0, steps.length - 1));

        story.dataset.activeIndex = String(safeIndex);
        steps.forEach((step, stepIndex) => {
          step.dataset.active = stepIndex === safeIndex ? "true" : "false";
        });
        visuals.forEach((visual, visualIndex) => {
          visual.dataset.active = visualIndex === safeIndex ? "true" : "false";
        });
      }

      function closestStepIndex(story) {
        const steps = Array.from(story.querySelectorAll("[data-case-step]"));
        const viewportCenter = window.innerHeight * 0.5;
        let bestIndex = 0;
        let bestDistance = Number.POSITIVE_INFINITY;

        steps.forEach((step, index) => {
          const rect = step.getBoundingClientRect();
          const distance = Math.abs(rect.top + rect.height * 0.5 - viewportCenter);
          if (distance < bestDistance) {
            bestDistance = distance;
            bestIndex = index;
          }
        });

        return bestIndex;
      }

      function updateStories() {
        frame = 0;
        stories.forEach((story) => {
          const rect = story.getBoundingClientRect();
          const scrollable = Math.max(1, story.offsetHeight - window.innerHeight);
          const progress = clamp(-rect.top / scrollable);
          story.style.setProperty("--story-progress", progress.toFixed(4));
          setActive(story, closestStepIndex(story));
        });
      }

      function requestStoryUpdate() {
        if (frame) return;
        frame = window.requestAnimationFrame(updateStories);
      }

      stories.forEach((story) => {
        story.querySelectorAll("[data-case-step]").forEach((step) => {
          const activate = () => setActive(story, Number(step.dataset.caseIndex));
          step.addEventListener("pointerenter", activate);
          step.addEventListener("focusin", activate);
        });
      });

      window.addEventListener("scroll", requestStoryUpdate, { passive: true });
      window.addEventListener("resize", requestStoryUpdate);
      window.addEventListener("pageshow", requestStoryUpdate);
      reduceMotion.addEventListener("change", requestStoryUpdate);

      if ("IntersectionObserver" in window) {
        const phases = document.querySelectorAll("[data-arc-phase]");
        const observer = new IntersectionObserver(
          (entries) => {
            const visible = entries
              .filter((entry) => entry.isIntersecting)
              .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];
            if (visible) body.dataset.phase = visible.target.dataset.arcPhase;
          },
          { rootMargin: "-28% 0px -48%", threshold: 0 }
        );
        phases.forEach((phase) => observer.observe(phase));
      }

      updateStories();
    </script>
  </body>
</html>

<style>
  :root {
    color-scheme: dark;
    font-family: "Inter Variable", Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    --ink: #0b0e12;
    --cream: #f6ead4;
    --paper: #e9dbc0;
    --paper-ink: #16120c;
    --teal: #20d3bd;
    --cobalt: #6d87ff;
    --cobalt-deep: #101b46;
    --line: rgba(246, 234, 212, 0.18);
    background: var(--ink);
    color: var(--cream);
  }

  * { box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body { min-width: 320px; margin: 0; background: #0b0e12; }
  a { color: inherit; }
  h1, h2, p, ol { margin: 0; }

  .skip-link {
    position: fixed;
    top: 0.75rem;
    left: 0.75rem;
    z-index: 100;
    padding: 0.75rem 1rem;
    border-radius: 999px;
    background: #fff;
    color: #111;
    font-weight: 850;
    transform: translateY(-160%);
  }
  .skip-link:focus { transform: translateY(0); }

  .site-header {
    position: fixed;
    inset: 0.9rem 1rem auto;
    z-index: 20;
    width: min(78rem, calc(100% - 2rem));
    min-height: 3.5rem;
    margin-inline: auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    border: 1px solid rgba(255,255,255,.16);
    border-radius: 999px;
    padding: 0.55rem 0.65rem 0.55rem 1rem;
    background: rgba(9, 12, 15, 0.72);
    backdrop-filter: blur(18px) saturate(130%);
    box-shadow: 0 1rem 3rem rgba(0,0,0,.2);
    transition: border-color 400ms ease, background 400ms ease;
  }
  body[data-phase="bureau"] .site-header { border-color: rgba(109,135,255,.45); background: rgba(9,14,28,.82); }
  .header-brand { font-size: 1rem; font-weight: 900; text-decoration: none; white-space: nowrap; }
  .site-header nav { display: flex; align-items: center; gap: 0.1rem; }
  .site-header nav a {
    border-radius: 999px;
    padding: 0.65rem 0.82rem;
    color: rgba(246,234,212,.72);
    font-size: 0.9rem;
    font-weight: 760;
    text-decoration: none;
  }
  .site-header nav a:hover, .site-header nav a:focus-visible { background: rgba(255,255,255,.09); color: #fff; }

  .course-hero {
    position: relative;
    min-height: 100svh;
    overflow: hidden;
    display: grid;
    align-items: end;
    padding: clamp(7rem, 12vh, 10rem) max(1rem, calc((100vw - 78rem) / 2)) clamp(5rem, 10vh, 7rem);
  }
  .hero-image, .hero-shade { position: absolute; inset: 0; width: 100%; height: 100%; }
  .hero-image { object-fit: cover; object-position: 56% center; }
  .hero-shade {
    background:
      linear-gradient(90deg, rgba(5,7,8,.94) 0%, rgba(5,7,8,.7) 42%, rgba(5,7,8,.14) 75%),
      linear-gradient(0deg, rgba(5,7,8,.82) 0%, transparent 45%);
  }
  .hero-content { position: relative; z-index: 2; width: min(63rem, 100%); min-width: 0; }
  .hero-kicker, .section-index {
    color: var(--teal);
    font-family: "JetBrains Mono Variable", "JetBrains Mono", ui-monospace, monospace;
    font-size: 0.76rem;
    font-weight: 760;
    letter-spacing: .12em;
    text-transform: uppercase;
  }
  .hero-content h1 { margin-top: 0.8rem; font-weight: 850; letter-spacing: -0.055em; line-height: .83; }
  .hero-content h1 > span { display: block; max-width: 9.7ch; font-size: clamp(4.4rem, 10vw, 9.4rem); }
  .hero-content h1 small {
    display: block;
    margin-top: 1.3rem;
    font-size: clamp(1.75rem, 3.4vw, 3.4rem);
    font-weight: 620;
    letter-spacing: -0.045em;
    line-height: .98;
  }
  .hero-summary { max-width: 43rem; margin-top: 1.25rem; color: rgba(246,234,212,.74); font-size: clamp(1.02rem, 1.5vw, 1.22rem); line-height: 1.6; }
  .hero-actions, .close-actions { display: flex; flex-wrap: wrap; align-items: center; gap: 0.75rem; margin-top: 1.5rem; }
  .button {
    min-height: 3rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid transparent;
    border-radius: 999px;
    padding: 0.75rem 1.08rem;
    font-weight: 850;
    text-decoration: none;
    transition: transform 180ms ease, background 180ms ease, border-color 180ms ease;
  }
  .button:hover, .button:focus-visible, .text-link:hover, .text-link:focus-visible { transform: translateY(-2px); }
  .button.primary { background: var(--teal); color: #06120f; }
  .button.glass { border-color: rgba(255,255,255,.24); background: rgba(255,255,255,.08); color: #fff; backdrop-filter: blur(12px); }
  .hero-scroll {
    position: absolute;
    right: max(1rem, calc((100vw - 78rem) / 2));
    bottom: 2rem;
    z-index: 2;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: rgba(246,234,212,.68);
    font-family: "JetBrains Mono Variable", "JetBrains Mono", monospace;
    font-size: .72rem;
    text-decoration: none;
    text-transform: uppercase;
  }
  .hero-scroll i { width: 3.5rem; height: 1px; background: var(--teal); transform-origin: left; animation: scan 2.4s ease-in-out infinite; }

  .hero-kicker { animation: enter .7s .08s both; }
  .hero-content h1 { animation: enter .9s .16s both; }
  .hero-summary { animation: enter .9s .28s both; }
  .hero-actions { animation: enter .9s .38s both; }
  @keyframes enter { from { opacity: 0; transform: translateY(2rem); } to { opacity: 1; transform: translateY(0); } }
  @keyframes scan { 0%,100% { transform: scaleX(.25); opacity: .35; } 50% { transform: scaleX(1); opacity: 1; } }

  .progression {
    width: min(78rem, calc(100% - 2rem));
    margin-inline: auto;
    padding: clamp(5rem, 9vw, 9rem) 0;
    display: grid;
    grid-template-columns: minmax(8rem,.42fr) minmax(0,1.05fr) minmax(22rem,.85fr);
    gap: clamp(1.5rem,4vw,4rem);
    align-items: start;
  }
  .progression h2 { font-size: clamp(2.4rem, 3.6vw, 3.8rem); line-height: .98; letter-spacing: -.045em; }
  .method h2, .course-close h2 { font-size: clamp(2.7rem, 6vw, 6.2rem); line-height: .93; letter-spacing: -.055em; }
  .progression p:last-child { color: rgba(246,234,212,.7); font-size: 1.05rem; line-height: 1.7; }

  .text-link { display: inline-flex; gap: .55rem; font-weight: 850; text-underline-offset: .25em; transition: transform 180ms ease; }

  .handoff {
    position: relative;
    min-height: min(86svh, 52rem);
    overflow: hidden;
    display: grid;
    align-items: end;
    padding: clamp(5rem, 10vw, 9rem) max(1rem, calc((100vw - 78rem) / 2));
    background: #090f22;
    color: #f3f4ff;
  }
  .handoff-image,
  .handoff-shade { position: absolute; inset: 0; width: 100%; height: 100%; }
  .handoff-image { object-fit: cover; object-position: center; }
  .handoff-shade {
    background:
      linear-gradient(90deg, rgba(5,9,22,.93) 0%, rgba(5,9,22,.68) 52%, rgba(5,9,22,.18) 82%),
      linear-gradient(0deg, rgba(5,9,22,.86), transparent 58%);
  }
  .handoff-copy { position: relative; z-index: 2; width: min(56rem, 100%); }
  .handoff .section-index { color: #aebaff; }
  .handoff h2 { max-width: 15ch; margin: .85rem 0 0; font-size: clamp(3rem, 7vw, 7rem); line-height: .91; letter-spacing: -.06em; }
  .handoff-copy > p:last-child { max-width: 40rem; margin-top: 1.25rem; color: rgba(239,242,255,.72); font-size: 1.08rem; line-height: 1.65; }

  .method { padding: clamp(5rem,10vw,10rem) max(1rem, calc((100vw - 78rem) / 2)); background: #090c12; }
  .method h2 { max-width: 12ch; margin-top: .9rem; }
  .method-flow { margin-top: clamp(3rem,7vw,7rem); display: grid; grid-template-columns: repeat(3,minmax(0,1fr)); border-top: 1px solid var(--line); }
  .method-flow div { min-height: 15rem; padding: 1.2rem 1.5rem 1.5rem 0; border-bottom: 1px solid var(--line); }
  .method-flow div + div { border-left: 1px solid var(--line); padding-left: 1.5rem; }
  .method-flow span { display: block; color: var(--teal); font-family: "JetBrains Mono Variable", "JetBrains Mono", monospace; font-size: .75rem; }
  .method-flow strong { display: block; margin-top: 4rem; font-size: 1.55rem; }
  .method-flow p { max-width: 25rem; margin-top: .55rem; color: rgba(246,234,212,.64); line-height: 1.55; }

  .course-close { padding: clamp(5rem,10vw,10rem) max(1rem, calc((100vw - 78rem) / 2)); background: #e8dcc6; color: #16120c; }
  .course-close .section-index { color: #334ba9; }
  .course-close h2 { margin-top: .9rem; }
  .button.paper { background: #18140e; color: #fff6e5; }
  .button.cobalt { background: #526ee8; color: #fff; }
  .dark-link { margin-left: .35rem; color: #2c3976; }

  footer { display: flex; justify-content: space-between; gap: 2rem; padding: 2rem max(1rem, calc((100vw - 78rem) / 2)); background: #07090d; color: rgba(246,234,212,.66); }
  footer > a { color: #fff; font-weight: 850; text-decoration: none; }
  footer nav { display: flex; flex-wrap: wrap; gap: 1.2rem; }
  footer nav a { text-underline-offset: .2em; }

  :focus-visible { outline: 3px solid #fff; outline-offset: 4px; }
  .course-close :focus-visible { outline-color: #16120c; }

  @media (max-width: 900px) {
    .site-header { position: absolute; align-items: flex-start; flex-direction: column; border-radius: 1.2rem; }
    .site-header nav { width: 100%; overflow-x: auto; padding-bottom: .1rem; }
    .site-header nav a { flex: 0 0 auto; padding-inline: .6rem; }
    .course-hero { min-height: 46rem; padding-top: 9.5rem; }
    .hero-image { object-position: 64% center; }
    .hero-content h1 > span { font-size: clamp(3.8rem,15vw,7rem); }
    .hero-scroll { display: none; }
    .progression { grid-template-columns: 1fr; }
    .progression h2 { max-width: 13ch; }
    .method-flow { grid-template-columns: 1fr; }
    .method-flow div { min-height: auto; padding: 1.2rem 0 2rem; }
    .method-flow div + div { border-left: 0; padding-left: 0; }
    .method-flow strong { margin-top: 2rem; }
  }

  @media (max-width: 560px) {
    .course-hero { min-height: 42rem; }
    .site-header nav {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      overflow: visible;
      padding-bottom: 0;
