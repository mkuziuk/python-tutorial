---
import { Image } from 'astro:assets';
import '@fontsource-variable/inter';
import '@fontsource-variable/jetbrains-mono';

import archiveDesk from '../assets/case-desk-hero.png';
import bureauLab from '../assets/bureau-data-lab.png';
import course from '../data/course.json';
import { homeStoryDetails } from '../data/home-stories';

const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

const withBase = (path: string) => `${base}${path.replace(/^\//, '')}`;
const archive = course.arcs.find((arc) => arc.id === 'part-1')!;
const bureau = course.arcs.find((arc) => arc.id === 'part-2')!;

const prepareCases = (arc: (typeof course.arcs)[number], offset = 0) =>
  arc.cases.map((item, index) => {
    const detail = homeStoryDetails[item.number];
    if (!detail) throw new Error(`Missing homepage story metadata for ${item.number}`);
    return {
      ...item,
      ...detail,
      entry: String(index + offset + 1).padStart(2, '0'),
      href: withBase(item.route),
    };
  });

const archiveCases = prepareCases(archive);
const bureauCases = prepareCases(bureau, archiveCases.length);
const guideLink = withBase('/field-guide/');
const materialsLink = withBase('/materials/');
const skillMapLink = withBase('/skill-map/');
const canonical = Astro.site ? new URL(base, Astro.site) : null;
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="Десять учебных проектов: четыре Python-скрипта и шесть тетрадей Jupyter по анализу данных и машинному обучению."
    />
    <meta name="theme-color" content="#f4eddc" />
    <meta property="og:title" content="Python-расследования" />
    <meta
      property="og:description"
      content="Учитесь на практике: создайте четыре программы на Python, затем проведите шесть исследований в Jupyter."
    />
    <meta property="og:type" content="website" />
    {canonical && <link rel="canonical" href={canonical} />}
    <title>Python-расследования · десять учебных дел</title>
    <link rel="icon" href={`${base}images/favicon.svg`} />
  </head>
  <body data-phase="archive">
    <a class="skip-link" href="#course-main">К основному содержанию</a>

    <header class="site-header">
      <a class="header-brand" href={base} aria-current="page">
        <span aria-hidden="true">P/10</span>
        Python-расследования
      </a>
      <nav aria-label="Основная навигация">
        <a href="#archive">Часть I</a>
        <a href="#bureau">Часть II</a>
        <a href={materialsLink}>Материалы</a>
        <a href={guideLink}>Справочник</a>
      </nav>
      <a class="header-start" href={archiveCases[0].href}>Начать <span aria-hidden="true">↗</span></a>
    </header>

    <main id="course-main">
      <section class="course-hero" aria-labelledby="home-title" data-arc-phase="archive">
        <div class="margin-rule" aria-hidden="true"></div>
        <div class="hero-inner">
          <div class="hero-copy">
            <p class="eyebrow">Проектный учебник · Python и машинное обучение</p>
            <h1 id="home-title">Python-<br />расследования</h1>
            <p class="hero-lede">
              Десять учебных дел: четыре программы на Python и шесть тетрадей Jupyter.
              Разберите готовый пример, дополните код и проверьте вывод на материалах расследования.
            </p>
            <div class="hero-actions">
              <a class="button button-ink" href={archiveCases[0].href}>Начать с дела № 01</a>
              <a class="text-link" href="#archive">Смотреть все 10 дел <span aria-hidden="true">↓</span></a>
            </div>
            <div class="manifest" aria-label="В курсе 10 дел: 4 Python-скрипта и 6 тетрадей Jupyter">
              <span class="manifest-prompt" aria-hidden="true">›</span>
              <span class="manifest-copy">дел: 10 · скриптов python: 4 · тетрадей jupyter: 6</span>
              <i aria-hidden="true"></i>
            </div>
          </div>

          <figure class="evidence-photo hero-photo reveal-photo">
            <span class="tape tape-top" aria-hidden="true"></span>
            <span class="tape tape-side" aria-hidden="true"></span>
            <Image
              src={archiveDesk}
              widths={[640, 960, 1280]}
              sizes="(min-width: 900px) 48vw, 92vw"
              format="avif"
              loading="eager"
              fetchpriority="high"
              alt="Ночной рабочий стол с ноутбуком, документами и материалами расследования"
            />
            <figcaption>фото 01 — северный стол, архив</figcaption>
            <span class="stamp stamp-open" aria-hidden="true">вскрыто</span>
          </figure>
        </div>

        <div class="ledger-preview" aria-hidden="true">
          <span>№ дела</span>
          <span>учебная задача</span>
          <span>инструмент</span>
          <span>время</span>
          <span>статус</span>
        </div>
      </section>

      <section class="course-section archive-section" id="archive" aria-labelledby="archive-title" data-arc-phase="archive">
        <div class="section-shell">
          <header class="section-heading">
            <div>
              <p class="eyebrow">Часть I · Архив · записи 01–04</p>
              <h2 id="archive-title">Четыре дела —<br />четыре программы на Python</h2>
            </div>
            <p>
              Сравните тексты, найдите совпадения, разберите письмо и соберите улики
              в итоговый отчёт. Опыт программирования не требуется.
            </p>
          </header>

          <div class="course-ledger">
            <div class="ledger-head" aria-hidden="true">
              <span>№</span>
              <span>Дело и результат</span>
              <span>Темы</span>
              <span>Формат</span>
              <span>Готово</span>
            </div>
            <ol aria-label="Четыре проекта первой части">
              {archiveCases.map((item) => (
                <li class="ledger-item reveal-row">
                  <a href={item.href}>
                    <span class="entry-number">Д-{item.entry}</span>
                    <span class="entry-main">
                      <strong>{item.title}</strong>
                      <span>{item.outcome}</span>
                    </span>
                    <span class="entry-topics">{item.concepts.slice(0, 3).join(' · ')}</span>
                    <span class="entry-meta">{item.format}<br />{item.time}</span>
                    <span class="entry-check" aria-hidden="true">[ ]</span>
                  </a>
                </li>
              ))}
            </ol>
          </div>

          <div class="section-action">
            <a class="line-link" href={withBase(archive.route)}>
              Открыть обзор части I <span aria-hidden="true">↗</span>
            </a>
            <span>4 проекта · Python-скрипты · 90–150 минут каждый</span>
          </div>
        </div>
      </section>

      <section class="handoff" aria-labelledby="handoff-title" data-arc-phase="bureau">
        <div class="handoff-inner">
          <figure class="evidence-photo bureau-photo reveal-photo">
            <span class="tape tape-top" aria-hidden="true"></span>
            <Image
              src={bureauLab}
              widths={[768, 1280, 1717]}
              sizes="(min-width: 900px) 56vw, 92vw"
              format="avif"
              loading="lazy"
              alt="Аналитик сверяет таблицу с графиками и матрицей ошибок на ноутбуке"
            />
            <figcaption>фото 02 — аналитическая лаборатория, бюро</figcaption>
            <span class="stamp stamp-recruit" aria-hidden="true">вербовка<br />04.2026</span>
          </figure>

          <div class="handoff-copy">
            <p class="eyebrow">Запись 05 · смена инструмента</p>
            <h2 id="handoff-title">Дальше — Бюро:<br />вместо документов — данные.</h2>
            <p>
              Та же привычка проверять выводы, но теперь в Jupyter:
              таблицы, модели, метрики и ошибки на новых примерах.
            </p>
            <a class="line-link" href="#bureau">Перейти к части II <span aria-hidden="true">↓</span></a>
          </div>
        </div>
      </section>

      <section class="course-section bureau-section" id="bureau" aria-labelledby="bureau-title" data-arc-phase="bureau">
        <div class="section-shell">
          <header class="section-heading">
            <div>
              <p class="eyebrow">Часть II · Бюро · записи 05–10</p>
              <h2 id="bureau-title">Шесть расследований —<br />шесть тетрадей Jupyter</h2>
            </div>
            <p>
              Подготовьте данные, разделите выборку, сравните модели и разберите ошибки.
              Каждая тетрадь заканчивается проверяемым результатом.
            </p>
          </header>

          <div class="course-ledger">
            <div class="ledger-head" aria-hidden="true">
              <span>№</span>
              <span>Расследование и вывод</span>
              <span>Темы</span>
              <span>Формат</span>
              <span>Готово</span>
            </div>
            <ol start="5" aria-label="Шесть проектов второй части">
              {bureauCases.map((item) => (
                <li class="ledger-item reveal-row">
                  <a href={item.href}>
                    <span class="entry-number">Д-{item.entry}</span>
                    <span class="entry-main">
                      <strong>{item.title}</strong>
                      <span>{item.outcome}</span>
                    </span>
                    <span class="entry-topics">{item.concepts.slice(0, 3).join(' · ')}</span>
                    <span class="entry-meta">{item.format}<br />{item.time}</span>
                    <span class="entry-check" aria-hidden="true">[ ]</span>
                  </a>
                </li>
              ))}
            </ol>
          </div>

          <div class="section-action">
            <a class="line-link" href={withBase(bureau.route)}>
              Открыть обзор части II <span aria-hidden="true">↗</span>
            </a>
            <span>6 проектов · Jupyter Notebook · от 3 часов</span>
          </div>
        </div>
      </section>

      <section class="back-cover" aria-labelledby="method-title">
        <div class="back-cover-inner">
          <div class="method">
            <p class="eyebrow">Рабочий порядок</p>
            <h2 id="method-title">Как устроено каждое расследование</h2>
            <ol>
              <li>
                <span>01</span>
                <p><strong>Воспроизведите</strong> результат из досье</p>
              </li>
              <li>
                <span>02</span>
                <p><strong>Проверьте</strong> данные, разбиение и ошибки</p>
              </li>
              <li>
                <span>03</span>
                <p><strong>Запишите</strong> метрики и ограничения модели</p>
              </li>
            </ol>
          </div>

          <div class="closing">
            <p class="eyebrow">Выберите точку входа</p>
            <h2>С чего начать</h2>
            <p>
              Новичкам — первый скрипт. Если уверенно работаете с функциями,
              коллекциями и файлами — переходите к Jupyter.
            </p>
            <div class="closing-actions">
              <a class="button button-paper" href={archiveCases[0].href}>Часть I — первый скрипт</a>
              <a class="button button-blue" href={bureauCases[0].href}>Часть II — первая тетрадь</a>
              <a class="line-link light-link" href={skillMapLink}>Сравнить навыки двух частей</a>
            </div>
          </div>
        </div>
      </section>
    </main>

    <footer>
      <a class="footer-brand" href={base}>Python-расследования</a>
      <p>Проектный учебник по Python и классическому машинному обучению.</p>
      <nav aria-label="Ссылки в подвале">
        <a href={materialsLink}>Материалы</a>
        <a href={guideLink}>Справочник</a>
        <a href={skillMapLink}>Карта навыков</a>
      </nav>
    </footer>

    <script is:inline type="module">
      const body = document.body;
      const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)");

      if (!reduceMotion.matches && "IntersectionObserver" in window) {
        body.classList.add("motion-ready");

        const revealObserver = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting) return;
              entry.target.classList.add("is-visible");
              if (entry.target.classList.contains("reveal-row")) {
                const check = entry.target.querySelector(".entry-check");
                if (check) check.textContent = "[x]";
              }
              revealObserver.unobserve(entry.target);
            });
          },
          { rootMargin: "0px 0px -16% 0px", threshold: 0.18 }
        );

        document.querySelectorAll(".reveal-row, .reveal-photo").forEach((item) => {
          revealObserver.observe(item);
        });
      }

      if ("IntersectionObserver" in window) {
        const phaseObserver = new IntersectionObserver(
          (entries) => {
            const active = entries
              .filter((entry) => entry.isIntersecting)
              .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];
            if (active) body.dataset.phase = active.target.dataset.arcPhase;
          },
          { rootMargin: "-32% 0px -56% 0px", threshold: 0 }
        );

        document.querySelectorAll("[data-arc-phase]").forEach((section) => {
          phaseObserver.observe(section);
        });
      }
    </script>
  </body>
</html>

<style>
  :root {
    color-scheme: light;
    font-family: "Inter Variable", Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    --paper-warm: #f4eddc;
    --paper-warm-deep: #e9dec7;
    --paper-cool: #edf0f6;
    --paper-cool-deep: #dce2ee;
    --ink: #17140d;
    --ink-cool: #10131c;
    --graph-warm: rgba(23, 20, 13, 0.065);
    --graph-cool: rgba(34, 51, 96, 0.07);
    --hairline: rgba(23, 20, 13, 0.18);
    --hairline-cool: rgba(37, 52, 91, 0.2);
    --marker-teal: #14786d;
    --cobalt: #4054d6;
    --stamp-red: #b93627;
    --mono: "JetBrains Mono Variable", "JetBrains Mono", ui-monospace, SFMono-Regular, Consolas, monospace;
    background: var(--paper-warm);
    color: var(--ink);
  }

  * {
    box-sizing: border-box;
  }

  html {
    min-width: 320px;
    scroll-behavior: smooth;
    scroll-padding-top: 5.5rem;
  }

  body {
    min-width: 320px;
    margin: 0;
    overflow-x: hidden;
    background: var(--paper-warm);
    color: var(--ink);
  }

  a {
    color: inherit;
  }

  h1,
  h2,
  p,
  figure,
  ol {
    margin: 0;
  }

  .skip-link {
    position: fixed;
    top: 0.75rem;
    left: 0.75rem;
    z-index: 100;
    padding: 0.8rem 1rem;
    background: var(--ink);
    color: var(--paper-warm);
    font-weight: 800;
    transform: translateY(-160%);
  }

  .skip-link:focus {
    transform: translateY(0);
  }

  .site-header {
    position: fixed;
    inset: 0 0 auto;
    z-index: 30;
    min-height: 4.75rem;
    display: grid;
    grid-template-columns: minmax(15rem, 1fr) auto minmax(15rem, 1fr);
    align-items: center;
    gap: 2rem;
    padding: 0.75rem max(1rem, calc((100vw - 86rem) / 2));
    border-bottom: 1px solid var(--hairline);
    background: color-mix(in srgb, var(--paper-warm) 90%, transparent);
    backdrop-filter: blur(16px);
    transition: color 350ms ease, background 350ms ease, border-color 350ms ease;
  }

  body[data-phase="bureau"] .site-header {
    border-color: var(--hairline-cool);
    background: color-mix(in srgb, var(--paper-cool) 90%, transparent);
    color: var(--ink-cool);
  }

  .header-brand {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.93rem;
    font-weight: 850;
    text-decoration: none;
    white-space: nowrap;
  }

  .header-brand span {
    display: grid;
    width: 2.35rem;
    height: 2.35rem;
    place-items: center;
    background: var(--ink);
    color: var(--paper-warm);
    font-family: var(--mono);
    font-size: 0.64rem;
    letter-spacing: -0.04em;
  }

  body[data-phase="bureau"] .header-brand span {
    background: var(--cobalt);
    color: white;
  }

  .site-header nav {
    display: flex;
    align-items: center;
    gap: 1.4rem;
  }

  .site-header nav a,
  .header-start {
    font-family: var(--mono);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    text-decoration: none;
    text-transform: uppercase;
  }

  .site-header nav a {
    padding-block: 0.5rem;
    border-bottom: 1px solid transparent;
  }

  .site-header nav a:hover,
  .site-header nav a:focus-visible {
    border-color: currentColor;
  }

  .header-start {
    justify-self: end;
    padding: 0.7rem 0.9rem;
    background: var(--ink);
    color: var(--paper-warm);
  }

  body[data-phase="bureau"] .header-start {
    background: var(--cobalt);
    color: white;
  }

  .course-hero {
    position: relative;
    min-height: 100svh;
    overflow: hidden;
    padding: clamp(7rem, 13vh, 9rem) max(1rem, calc((100vw - 86rem) / 2)) 0;
    background-color: var(--paper-warm);
    background-image:
      linear-gradient(var(--graph-warm) 1px, transparent 1px),
      linear-gradient(90deg, var(--graph-warm) 1px, transparent 1px);
    background-size: 32px 32px;
  }

  .course-hero::after {
    position: absolute;
    inset: 0;
    content: "";
    pointer-events: none;
    background: radial-gradient(circle at 35% 40%, transparent 0, rgba(244, 237, 220, 0.52) 74%);
  }

  .margin-rule {
    position: absolute;
    z-index: 1;
    top: 4.75rem;
    bottom: 0;
    left: max(2.75rem, calc((100vw - 93rem) / 2));
    width: 1px;
    background: rgba(185, 54, 39, 0.56);
    transform-origin: top;
    animation: draw-rule 1.2s 0.2s both ease-out;
  }

  .hero-inner {
    position: relative;
    z-index: 2;
    width: min(86rem, 100%);
    min-height: calc(100svh - clamp(7rem, 13vh, 9rem) - 5.3rem);
    margin-inline: auto;
    display: grid;
    grid-template-columns: minmax(0, 0.94fr) minmax(28rem, 0.82fr);
    gap: clamp(3rem, 6vw, 7rem);
    align-items: center;
    padding-block: clamp(2rem, 5vh, 4rem) 4rem;
  }

  .hero-copy {
    min-width: 0;
  }

  .eyebrow {
    color: var(--marker-teal);
    font-family: var(--mono);
    font-size: 0.72rem;
    font-weight: 750;
    letter-spacing: 0.1em;
    line-height: 1.5;
    text-transform: uppercase;
  }

  .hero-copy .eyebrow {
    animation: hero-enter 650ms 80ms both ease-out;
  }

  h1 {
    max-width: 10ch;
    margin-top: 0.85rem;
    font-size: clamp(4.15rem, 6.8vw, 6.8rem);
    font-weight: 850;
    letter-spacing: -0.065em;
    line-height: 0.78;
    text-wrap: balance;
    animation: hero-enter 780ms 140ms both ease-out;
  }

  .hero-lede {
    max-width: 43rem;
    margin-top: clamp(1.7rem, 3vh, 2.5rem);
    font-size: clamp(1.03rem, 1.45vw, 1.22rem);
    line-height: 1.65;
    animation: hero-enter 780ms 240ms both ease-out;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1.25rem;
    margin-top: 1.75rem;
    animation: hero-enter 780ms 320ms both ease-out;
  }

  .button {
    min-height: 3.25rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid transparent;
    padding: 0.8rem 1.1rem;
    font-size: 0.92rem;
    font-weight: 850;
    text-decoration: none;
    transition: transform 180ms ease, background 180ms ease, color 180ms ease;
  }

  .button:hover,
  .button:focus-visible,
  .line-link:hover,
  .line-link:focus-visible,
  .text-link:hover,
  .text-link:focus-visible {
    transform: translateY(-2px);
  }

  .button-ink {
    background: var(--ink);
    color: var(--paper-warm);
  }

  .button-ink:hover,
  .button-ink:focus-visible {
    background: var(--marker-teal);
  }

  .text-link,
  .line-link {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-weight: 800;
    text-underline-offset: 0.22em;
    transition: transform 180ms ease;
  }

  .text-link {
    font-size: 0.9rem;
  }

  .manifest {
    width: fit-content;
    max-width: 100%;
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-top: clamp(2.5rem, 6vh, 4.5rem);
    padding-top: 0.9rem;
    border-top: 1px solid var(--hairline);
    color: rgba(23, 20, 13, 0.72);
    font-family: var(--mono);
    font-size: clamp(0.66rem, 1vw, 0.78rem);
    white-space: nowrap;
  }

  .manifest-prompt {
    color: var(--marker-teal);
    font-weight: 800;
  }

  .manifest-copy {
    display: inline-block;
    overflow: hidden;
    width: 54ch;
    max-width: 100%;
    animation: type-manifest 1.8s 750ms steps(54, end) both;
  }

  .manifest i {
    width: 0.55em;
    height: 1.15em;
    background: var(--marker-teal);
    animation: cursor-blink 850ms step-end infinite;
  }

  .evidence-photo {
    position: relative;
    padding: 0.62rem 0.62rem 2.3rem;
    background: #fffdf7;
    box-shadow: 0 1.5rem 4rem rgba(47, 38, 21, 0.22);
    transform: rotate(-1.2deg);
  }

  .evidence-photo img {
    width: 100%;
    height: auto;
    display: block;
    aspect-ratio: 4 / 3;
    object-fit: cover;
  }

  .evidence-photo figcaption {
