---
import '@fontsource-variable/inter';
import '@fontsource-variable/jetbrains-mono';

import course from '../../data/course.json';
import { homeStoryDetails } from '../../data/home-stories';

const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

const withBase = (path: string) => `${base}${path.replace(/^\//, '')}`;
const archive = course.arcs.find((arc) => arc.id === 'part-1')!;
const bureau = course.arcs.find((arc) => arc.id === 'part-2')!;

const cases = archive.cases.map((item, index) => {
  const detail = homeStoryDetails[item.number];
  if (!detail) throw new Error(`Missing homepage story metadata for ${item.number}`);

  return {
    ...item,
    ...detail,
    index: String(index + 1).padStart(2, '0'),
    href: withBase(item.route),
    solutionHref: withBase(item.solutionRoute),
  };
});

const materialsLink = withBase('/materials/');
const guideLink = withBase('/field-guide/');
const skillMapLink = withBase('/skill-map/');
const canonical = Astro.site ? new URL(`${base}cases/`, Astro.site) : null;
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="Четыре проекта по основам Python: от обработки текстов и писем до итоговой цепочки улик."
    />
    <meta name="theme-color" content="#eef1f4" />
    <meta property="og:title" content="Расследования · Часть I" />
    <meta
      property="og:description"
      content="Четыре программы на Python, связанные одной цепочкой JSON-артефактов."
    />
    <meta property="og:type" content="website" />
    {canonical && <link rel="canonical" href={canonical} />}
    <title>Расследования · Часть I · Python-расследования</title>
    <link rel="icon" href={`${base}images/favicon.svg`} />
  </head>
  <body>
    <a class="skip-link" href="#cases-main">К основному содержанию</a>

    <header class="site-header">
      <a class="header-brand" href={base}>
        <span aria-hidden="true">P/10</span>
        Python-расследования
      </a>
      <nav aria-label="Основная навигация">
        <a href={withBase(archive.route)} aria-current="page">Часть I</a>
        <a href={withBase(bureau.route)}>Часть II</a>
        <a href={materialsLink}>Материалы</a>
        <a href={guideLink}>Справочник</a>
      </nav>
      <a class="header-start" href={cases[0].href}>Начать I-01 <span aria-hidden="true">↗</span></a>
    </header>

    <main id="cases-main">
      <section class="docket-hero" aria-labelledby="cases-title">
        <div class="hero-shell">
          <div class="hero-copy">
            <p class="eyebrow">Городской архив · Первая арка</p>
            <h1 id="cases-title">Расследования</h1>
            <div class="double-rule" aria-hidden="true"></div>
            <p class="hero-lede">
              Четыре программы, одна цепочка улик. Каждая читает JSON предыдущей
              и сохраняет свой — к 15 марта 2026 года цепочка должна быть собрана целиком.
            </p>
            <div class="hero-actions">
              <a class="button primary-button" href={cases[0].href}>Начать с I-01</a>
              <a class="text-link" href="#evidence-chain">Просмотреть цепочку <span aria-hidden="true">↓</span></a>
            </div>
            <p class="marginalia">
              Все наборы — на странице <a href={materialsLink}>Материалы</a>.
              Забыли модуль — откройте <a href={guideLink}>Справочник</a>.
            </p>
          </div>

          <aside class="transfer-slip" aria-label="Состав цепочки улик">
            <span class="slip-tab">Дело А-0315</span>
            <div class="slip-heading">
              <p>Витрина</p>
              <strong>«Северный стол»</strong>
              <span>Срок передачи · 15.03.2026</span>
            </div>
            <ol>
              {cases.map((item, index) => (
                <li style={`--node-delay: ${index * 120}ms`}>
                  <i aria-hidden="true"></i>
                  <span>I-{item.index}</span>
                  <code>{item.artifact}</code>
                </li>
              ))}
            </ol>
            <p class="slip-footer">
              Статус цепочки <strong>04 / 04</strong>
            </p>
            <span class="hero-stamp" aria-hidden="true">к передаче</span>
          </aside>
        </div>
      </section>

      <section class="chain-section" id="evidence-chain" aria-labelledby="chain-title" data-chain>
        <div class="section-shell">
          <header class="section-heading">
            <div>
              <p class="eyebrow">Опись · четыре передачи</p>
              <h2 id="chain-title">Цепочка улик</h2>
            </div>
            <p>
              Результат каждого расследования становится входом следующего.
              Проходите записи по порядку, чтобы собрать финальный отчёт без пропусков.
            </p>
          </header>

          <div class="ledger-head" aria-hidden="true">
            <span>Запись</span>
            <span>Операция</span>
            <span>Передаваемый файл</span>
          </div>

          <ol class="chain-list">
            <span class="chain-track" aria-hidden="true"></span>
            <span class="chain-thread" aria-hidden="true"></span>
            {cases.map((item, index) => (
              <li class="chain-entry reveal-entry" style={`--entry-delay: ${index * 100}ms`}>
                <div class="case-index">
                  <span>I-{item.index}</span>
                  <small>{item.time}</small>
                </div>
                <span class="artifact-node" aria-hidden="true"><i></i></span>
                <article>
                  <p class="case-kicker">{item.kicker}</p>
                  <h3><a href={item.href}>{item.title}</a></h3>
                  <p>{item.summary}</p>
                  <dl>
                    <div>
                      <dt>Собираем</dt>
                      <dd>{item.tool}</dd>
                    </div>
                    <div>
                      <dt>Темы</dt>
                      <dd>{item.concepts.slice(0, 4).join(' · ')}</dd>
                    </div>
                  </dl>
                  <a class="case-action" href={item.href}>
                    Открыть расследование I-{item.index} <span aria-hidden="true">↗</span>
                  </a>
                </article>
                <div class="artifact-output">
                  <span class="received-stamp" aria-hidden="true">получено</span>
                  <p>Результат</p>
                  <code>{item.artifact}</code>
                  <span>{item.format}</span>
                </div>
              </li>
            ))}
          </ol>
        </div>
      </section>

      <section class="annex" aria-labelledby="annex-title">
        <div class="annex-shell">
          <div class="annex-title">
            <p class="eyebrow">Приложение А</p>
            <h2 id="annex-title">Разборы решений</h2>
            <p>Открывайте разбор после того, как самостоятельно собрали и запустили программу.</p>
          </div>

          <ol class="solution-ledger">
            {cases.map((item) => (
              <li>
                <span>I-{item.index}</span>
                <a href={item.solutionHref}>Разбор · {item.title}</a>
                <span class="after-stamp" aria-hidden="true">после сборки</span>
              </li>
            ))}
          </ol>
        </div>
      </section>

      <section class="protocol" aria-labelledby="protocol-title">
        <div class="section-shell">
          <header class="protocol-heading">
            <p class="eyebrow">Протокол прохождения</p>
            <h2 id="protocol-title">Порядок работы</h2>
          </header>

          <ol class="protocol-list">
            <li>
              <span>01</span>
              <h3>Скачайте набор</h3>
              <p>Откройте расследование и возьмите файлы из блока материалов в начале главы.</p>
            </li>
            <li>
              <span>02</span>
              <h3>Подготовьте среду</h3>
              <p>Создайте виртуальное окружение и установите зависимости из <code>requirements.txt</code>.</p>
            </li>
            <li>
              <span>03</span>
              <h3>Соберите программу</h3>
              <p>Добавляйте код небольшими шагами и сверяйте промежуточные значения с главой.</p>
            </li>
            <li>
              <span>04</span>
              <h3>Передайте результат</h3>
              <p>Сохраните JSON-артефакт и только затем открывайте разбор полного решения.</p>
            </li>
          </ol>
        </div>
      </section>

      <section class="deadline" aria-labelledby="deadline-title">
        <div class="deadline-shell">
          <div>
            <p class="eyebrow">Контрольный срок · 15.03.2026</p>
            <h2 id="deadline-title">Витрина открывается.<br />Цепочка начинается с I-01.</h2>
          </div>
          <div class="deadline-actions">
            <a class="button deadline-button" href={cases[0].href}>
              Кто оставил предупреждение? <span aria-hidden="true">↗</span>
            </a>
            <a href={materialsLink}>Скачать наборы — Материалы</a>
            <a href={guideLink}>Открыть Справочник</a>
            <a href={skillMapLink}>Посмотреть карту навыков</a>
          </div>
        </div>
      </section>
    </main>

    <footer>
      <a href={base}>Python-расследования</a>
      <p>Часть I · Архив · четыре программы</p>
      <nav aria-label="Ссылки в подвале">
        <a href={materialsLink}>Материалы</a>
        <a href={guideLink}>Справочник</a>
        <a href={withBase(bureau.route)}>Часть II</a>
      </nav>
    </footer>

    <script is:inline type="module">
      const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)");

      if (!reduceMotion.matches && "IntersectionObserver" in window) {
        document.body.classList.add("motion-ready");

        const chain = document.querySelector("[data-chain]");
        const chainObserver = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting) return;
              entry.target.classList.add("chain-active");
              chainObserver.unobserve(entry.target);
            });
          },
          { rootMargin: "0px 0px -18% 0px", threshold: 0.08 }
        );
        if (chain) chainObserver.observe(chain);

        const entryObserver = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting) return;
              entry.target.classList.add("entry-visible");
              entryObserver.unobserve(entry.target);
            });
          },
          { rootMargin: "0px 0px -12% 0px", threshold: 0.14 }
        );
        document.querySelectorAll(".reveal-entry").forEach((entry) => entryObserver.observe(entry));
      }
    </script>
  </body>
</html>

<style>
  :root {
    color-scheme: light;
    font-family: "Inter Variable", Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    --paper: #f7f5ee;
    --paper-blue: #eef1f4;
    --paper-blue-deep: #dce2e9;
    --ink: #15171c;
    --ink-soft: #454a55;
    --indigo: #3656d4;
    --indigo-dark: #20348b;
    --indigo-light: #8fa0ff;
    --signal-red: #c43b2a;
    --teal: #14786d;
    --rule: rgba(21, 23, 28, 0.2);
    --rule-strong: rgba(21, 23, 28, 0.72);
    --mono: "JetBrains Mono Variable", "JetBrains Mono", ui-monospace, SFMono-Regular, Consolas, monospace;
    background: var(--paper);
    color: var(--ink);
  }

  * {
    box-sizing: border-box;
  }

  html {
    min-width: 320px;
    scroll-behavior: smooth;
    scroll-padding-top: 5rem;
  }

  body {
    min-width: 320px;
    margin: 0;
    overflow-x: hidden;
    background: var(--paper);
    color: var(--ink);
  }

  a {
    color: inherit;
  }

  h1,
  h2,
  h3,
  p,
  ol,
  dl,
  dd {
    margin: 0;
  }

  .skip-link {
    position: fixed;
    top: 0.75rem;
    left: 0.75rem;
    z-index: 100;
    padding: 0.8rem 1rem;
    background: var(--ink);
    color: white;
    font-weight: 800;
    transform: translateY(-160%);
  }

  .skip-link:focus {
    transform: translateY(0);
  }

  .site-header {
    position: fixed;
    inset: 0 0 auto;
    z-index: 30;
    min-height: 4.75rem;
    display: grid;
    grid-template-columns: minmax(15rem, 1fr) auto minmax(15rem, 1fr);
    align-items: center;
    gap: 2rem;
    padding: 0.75rem max(1rem, calc((100vw - 86rem) / 2));
    border-bottom: 1px solid rgba(34, 52, 139, 0.2);
    background: color-mix(in srgb, var(--paper-blue) 92%, transparent);
    backdrop-filter: blur(16px);
  }

  .header-brand {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.93rem;
    font-weight: 850;
    text-decoration: none;
    white-space: nowrap;
  }

  .header-brand span {
    display: grid;
    width: 2.35rem;
    height: 2.35rem;
    place-items: center;
    background: var(--indigo);
    color: white;
    font-family: var(--mono);
    font-size: 0.64rem;
  }

  .site-header nav {
    display: flex;
    align-items: center;
    gap: 1.4rem;
  }

  .site-header nav a,
  .header-start {
    font-family: var(--mono);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    text-decoration: none;
    text-transform: uppercase;
  }

  .site-header nav a {
    padding-block: 0.5rem;
    border-bottom: 1px solid transparent;
  }

  .site-header nav a:hover,
  .site-header nav a:focus-visible,
  .site-header nav a[aria-current="page"] {
    border-color: currentColor;
  }

  .header-start {
    justify-self: end;
    padding: 0.7rem 0.9rem;
    background: var(--indigo);
    color: white;
  }

  .eyebrow {
    color: var(--indigo);
    font-family: var(--mono);
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    line-height: 1.5;
    text-transform: uppercase;
  }

  .docket-hero {
    min-height: 100svh;
    display: grid;
    align-items: center;
    padding: clamp(7rem, 13vh, 10rem) max(1rem, calc((100vw - 86rem) / 2)) clamp(4rem, 8vh, 7rem);
    background-color: var(--paper-blue);
    background-image: repeating-linear-gradient(
      to bottom,
      transparent 0,
      transparent 2.78rem,
      rgba(42, 65, 144, 0.075) 2.78rem,
      rgba(42, 65, 144, 0.075) calc(2.78rem + 1px)
    );
  }

  .hero-shell {
    width: min(86rem, 100%);
    margin-inline: auto;
    display: grid;
    grid-template-columns: minmax(0, 1.25fr) minmax(27rem, 0.7fr);
    gap: clamp(4rem, 8vw, 10rem);
    align-items: center;
  }

  .hero-copy {
    min-width: 0;
  }

  .hero-copy .eyebrow {
    animation: hero-enter 650ms 60ms both ease-out;
  }

  h1 {
    margin-top: 0.8rem;
    font-size: clamp(4.3rem, 7.2vw, 7.3rem);
    font-weight: 850;
    letter-spacing: -0.065em;
    line-height: 0.82;
    animation: hero-enter 800ms 120ms both ease-out;
  }

  .double-rule {
    height: 0.42rem;
    margin-top: clamp(2rem, 4vh, 3.2rem);
    border-block: 1px solid var(--rule-strong);
    animation: rule-enter 900ms 260ms both ease-out;
    transform-origin: left;
  }

  .hero-lede {
    max-width: 52rem;
    margin-top: 1.5rem;
    font-size: clamp(1.08rem, 1.65vw, 1.35rem);
    line-height: 1.68;
    animation: hero-enter 800ms 280ms both ease-out;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1.2rem;
    margin-top: 1.7rem;
    animation: hero-enter 800ms 360ms both ease-out;
  }

  .button {
    min-height: 3.3rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.7rem;
    border: 1px solid transparent;
    padding: 0.82rem 1.1rem;
    font-weight: 850;
    text-decoration: none;
    transition: transform 180ms ease, background 180ms ease, color 180ms ease;
  }

  .primary-button {
    background: var(--indigo);
    color: white;
  }

  .primary-button:hover,
  .primary-button:focus-visible {
    background: var(--teal);
  }

  .text-link,
  .case-action {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    font-weight: 800;
    text-underline-offset: 0.22em;
    transition: color 180ms ease, transform 180ms ease;
  }

  .button:hover,
  .button:focus-visible,
  .text-link:hover,
  .text-link:focus-visible,
  .case-action:hover,
  .case-action:focus-visible {
    transform: translateY(-2px);
  }

  .marginalia {
    max-width: 45rem;
    margin-top: clamp(2.8rem, 6vh, 5rem);
    padding-top: 0.9rem;
    border-top: 1px solid var(--rule);
    color: var(--ink-soft);
    font-family: var(--mono);
    font-size: 0.7rem;
    line-height: 1.7;
    animation: hero-enter 800ms 440ms both ease-out;
  }

  .marginalia a {
    color: var(--indigo-dark);
    font-weight: 800;
  }

  .transfer-slip {
    position: relative;
    min-height: 32rem;
    display: flex;
    flex-direction: column;
    padding: clamp(2rem, 4vw, 3.2rem);
    border: 1px solid rgba(255, 255, 255, 0.2);
    background:
      repeating-linear-gradient(
        to bottom,
        transparent 0,
        transparent 2.75rem,
        rgba(255, 255, 255, 0.075) 2.75rem,
        rgba(255, 255, 255, 0.075) calc(2.75rem + 1px)
      ),
      #16265f;
    color: white;
    box-shadow: 1.8rem 2rem 0 rgba(54, 86, 212, 0.14);
    clip-path: polygon(0 0, 38% 0, 42% 1.4rem, 100% 1.4rem, 100% 100%, 0 100%);
    animation: slip-enter 900ms 260ms both cubic-bezier(0.16, 1, 0.3, 1);
  }

  .slip-tab {
    position: absolute;
    top: 0.45rem;
    left: 1.1rem;
    color: var(--indigo-light);
    font-family: var(--mono);
    font-size: 0.64rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .slip-heading {
    padding-top: 1.1rem;
  }

  .slip-heading p,
  .slip-heading span,
  .slip-footer,
  .transfer-slip li {
    font-family: var(--mono);
  }

  .slip-heading p {
    color: var(--indigo-light);
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.09em;
    text-transform: uppercase;
  }

  .slip-heading strong {
    display: block;
    margin-top: 0.35rem;
    font-size: clamp(1.8rem, 3vw, 2.8rem);
    letter-spacing: -0.04em;
    line-height: 1;
  }

  .slip-heading span {
    display: block;
    margin-top: 0.75rem;
    color: rgba(255, 255, 255, 0.62);
    font-size: 0.66rem;
  }

  .transfer-slip ol {
    position: relative;
    flex: 1;
    display: grid;
    align-content: center;
    gap: 0;
    margin-top: 1.5rem;
    padding: 0;
    list-style: none;
  }

  .transfer-slip ol::before {
    position: absolute;
    top: 14%;
    bottom: 14%;
    left: 0.28rem;
    width: 2px;
    content: "";
    background: var(--signal-red);
    transform: scaleY(0);
    transform-origin: top;
    animation: slip-thread 1.3s 900ms both ease-out;
  }

  .transfer-slip li {
    position: relative;
    min-height: 3.75rem;
    display: grid;
    grid-template-columns: 2rem 3.4rem minmax(0, 1fr);
    align-items: center;
    border-bottom: 1px solid rgba(255, 255, 255, 0.16);
    font-size: 0.67rem;
  }

  .transfer-slip li i {
    position: relative;
    z-index: 1;
    width: 0.62rem;
    height: 0.62rem;
    border: 2px solid var(--signal-red);
    border-radius: 50%;
    background: #16265f;
  }

  .transfer-slip li span {
    color: var(--indigo-light);
    font-weight: 800;
  }

  .transfer-slip code {
    overflow: hidden;
    color: white;
    font: inherit;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .slip-footer {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding-top: 1rem;
    color: rgba(255, 255, 255, 0.56);
    font-size: 0.64rem;
  }

  .slip-footer strong {
    color: white;
  }

  .hero-stamp,
  .received-stamp,
  .after-stamp {
    border: 0.2rem double currentColor;
    color: var(--signal-red);
    font-family: var(--mono);
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .hero-stamp {
    position: absolute;
    right: -1rem;
    bottom: 2.2rem;
    padding: 0.55rem 0.75rem;
    font-size: 0.68rem;
    transform: rotate(-5deg);
    mix-blend-mode: screen;
  }

  .section-shell,
  .annex-shell,
  .deadline-shell {
    width: min(86rem, 100%);
    margin-inline: auto;
  }

  .chain-section {
    padding: clamp(6rem, 10vw, 10rem) max(1rem, calc((100vw - 86rem) / 2));
    background-color: var(--paper);
    background-image: repeating-linear-gradient(
      to bottom,
      transparent 0,
      transparent 3rem,
      rgba(21, 23, 28, 0.055) 3rem,
      rgba(21, 23, 28, 0.055) calc(3rem + 1px)
    );
  }

  .section-heading {
    display: grid;
