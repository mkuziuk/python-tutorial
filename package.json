{
  "name": "investigative-python",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "build:notebooks": "python3 tools/build_part2_notebooks.py",
    "build:part1-artifacts": "python3 tools/build_part1_artifacts.py",
    "build:part1-solutions": "python3 tools/build_part1_solution_pages.py",
    "build:archives": "python3 tools/build_case_archives.py",
    "build:datasets": "python3 tools/build_public_datasets.py",
    "test:python": "python3 tools/run_case_tests.py",
    "test:part1-artifacts": "python3 tools/build_part1_artifacts.py --check && python3 tools/run_part1_pipeline.py",
    "test:part1-solutions": "python3 tools/build_part1_solution_pages.py --check",
    "test:notebooks": "python3 tools/build_part2_notebooks.py --check && python3 tools/run_part2_notebooks.py",
    "test:manifest": "python3 tools/check_course_manifest.py",
    "test:archives": "python3 tools/build_case_archives.py --check",
    "test:datasets": "python3 tools/build_public_datasets.py --check",
    "test:links": "node tools/check_internal_links.mjs",
    "verify": "pnpm test:part1-artifacts && pnpm test:part1-solutions && pnpm test:python && pnpm test:notebooks && pnpm test:manifest && pnpm test:archives && pnpm test:datasets && pnpm build && pnpm test:links"
  },
  "dependencies": {
    "@astrojs/starlight": "^0.41.3",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource/spectral": "5.2.8",
    "astro": "^7.0.6",
    "sharp": "0.35.3"
  }
}
